<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="LADXHD_Launcher.OkayWindow"
        Title="Okay Dialog"
        Width="304" Height="120"
        CanResize="False"
        WindowStartupLocation="CenterScreen"
        CanMaximize="False"
		Icon="avares://Launcher/Resources/Icon.ico">

    <Grid Margin="0,0,0,0" RowDefinitions="*,Auto">
        <TextBlock x:Name="MessageLabel" Grid.Row="0" 
				   FontSize="11.5" 
				   TextWrapping="Wrap" 
				   TextAlignment="Center" 
				   HorizontalAlignment="Center" 
				   VerticalAlignment="Center" 
				   Margin="20,0,20,0" />

        <Button x:Name="OkButton" Grid.Row="1" 
				FontSize="11.5" 
				Content="OK" 
				Width="80" 
				HorizontalAlignment="Stretch" 
				HorizontalContentAlignment="Center" 
				VerticalContentAlignment="Center" 
				Margin="0,0,0,12" 
				Click="OkButton_Click" />
    </Grid>

</Window>